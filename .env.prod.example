# Production .env for docker-compose.prod.yml — copy next to the compose file
# on the server as `.env` and fill in. NEVER commit a filled-in copy.

# ── Required ──────────────────────────────────────────────────────────────────
# Postgres password (compose wires it into DATABASE_URL). `openssl rand -hex 16`
DB_PASSWORD=
# JWT signing secret, at least 32 bytes. `openssl rand -hex 32`
JWT_SECRET=

# ── Recommended ──────────────────────────────────────────────────────────────
# Host port the app is served on (frontend container).
WEB_PORT=80
# Public origin (used in email links; cosmetic while SMTP is unset).
APP_URL=http://212.33.206.34

# ── Image pins (default :latest from our registry) ───────────────────────────
#BACKEND_IMAGE=docker.netixsystem.com/idea-pop-backend:sha-abc1234
#FRONTEND_IMAGE=docker.netixsystem.com/idea-pop-frontend:sha-abc1234
#POSTGRES_IMAGE=docker.netixsystem.com/postgres:16-alpine

# ── HTTPS (once behind TLS) ───────────────────────────────────────────────────
#COOKIE_SECURE=true

# ── AI mission helper (keep DARK on the for-kids prod until sign-off — runbook §9.3;
#    also requires a frontend image built with NEXT_PUBLIC_MISSION_HELPER=true
#    AND outbound server access to the Metis API) ────────────────────────────
#MISSION_HELPER_ENABLED=true
#METIS_API_KEY=
#METIS_BASE_URL=https://api.metisai.ir/openai/v1
#METIS_MODEL=gpt-4o-mini
#HELPER_HOURLY_LIMIT=10
#HELP_MESSAGE_RETENTION_DAYS=90
