  "query": "SELECT id, title, slug, studio, difficulty, time_minutes, materials,\n                      mess_level, video_url, xp_reward, ai_generated, created_at\n               FROM quick_makes\n               WHERE ($1::text IS NULL OR studio = $1)\n               ORDER BY created_at DESC\n               LIMIT $2 OFFSET $3",
