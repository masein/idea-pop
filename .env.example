# ---- Backend ----
APP_PORT=8080
DATABASE_URL=postgres://ideapop:ideapop@localhost:5432/ideapop
RUST_LOG=info
JWT_SECRET=change-me-in-prod
# Adds Secure to the httpOnly auth refresh cookie — MUST be true in prod (https).
COOKIE_SECURE=false

# ---- Email (dev: MailHog) ----
SMTP_HOST=localhost
SMTP_PORT=1025

# ---- Storage (dev: MinIO, S3-compatible) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ideapop
S3_SECRET_KEY=ideapop123
S3_BUCKET=ideapop-projects

# ---- Stripe billing (Phase 6) ----
# Get these from the Stripe dashboard. Never commit real keys.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_MONTHLY=price_placeholder_monthly
STRIPE_PRICE_ANNUAL=price_placeholder_annual

# ---- Frontend ----
# The browser always calls same-origin /api/*; the Next server rewrites those
# to API_URL (set at BUILD time; compose passes http://backend:8080).
API_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=https://ideapop.app

# ---- AI mission helper (Metis AI, OpenAI-compatible) — see docs/runbook.md §9 ----
# The helper SHIPS DARK: with these unset/false the route 404s and no UI renders.
# METIS_API_KEY is a real secret — set it only in the server runtime, never here,
# never in the frontend. The browser never talks to Metis.
MISSION_HELPER_ENABLED=false
METIS_API_KEY=
METIS_BASE_URL=https://api.metisai.ir/openai/v1
METIS_MODEL=gpt-4o-mini
HELPER_HOURLY_LIMIT=10
# help_messages retention in days; unset or 0 = keep forever (purge disabled).
HELP_MESSAGE_RETENTION_DAYS=

# NEXT_PUBLIC_MISSION_HELPER is a FRONTEND BUILD-TIME flag (baked in by
# `next build`): set it in the frontend build environment, not the server.
NEXT_PUBLIC_MISSION_HELPER=false
